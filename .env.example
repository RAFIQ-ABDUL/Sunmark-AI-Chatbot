# Database
# Neon PostgreSQL Connection String (PGVector)
# Format: postgresql://[user]:[password]@[hostname]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-hostname-pooler.region.aws.neon.tech/neondb?sslmode=require

# LLM API Keys
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key
# Frontend 
NEXT_PUBLIC_API_URL=/api